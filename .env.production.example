# ============================================================================
# Production Environment Configuration for IXO USSD SupaMoto Server
# ============================================================================
# Copy this file to .env.production and fill in the actual values
# NEVER commit .env.production to version control
# ============================================================================

# ============================================================================
# Server Configuration
# ============================================================================
NODE_ENV=production
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info
LOG_NAME=ixo-ussd-supamoto
SERVER_DISABLE_REQUEST_LOGGING=false
TRUST_PROXY_ENABLED=true
METRICS_ENABLED=true

# ============================================================================
# Database Configuration
# ============================================================================
# Use DATABASE_URL for connection string (recommended)
DATABASE_URL=postgres://username:password@postgres:5432/ixo_ussd_supamoto

# Or use individual variables
PG_USER=postgres
PG_PASSWORD=CHANGE_ME_STRONG_PASSWORD
PG_HOST=postgres
PG_PORT=5432
PG_DATABASE=ixo_ussd_supamoto

# ============================================================================
# IXO Blockchain Configuration
# ============================================================================
# Network: devnet, testnet, or mainnet
CHAIN_NETWORK=mainnet
CHAIN_RPC_URL=https://rpc.ixo.earth

# Feegrant Configuration
FEEGRANT_URL=https://feegrant.ixo.earth
FEEGRANT_GRANTER=ixo1xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FEEGRANT_AUTH_MAINNET=YOUR_FEEGRANT_AUTH_TOKEN_HERE
FEEGRANT_AUTH_TESTNET=
FEEGRANT_AUTH_DEVNET=

# ============================================================================
# Matrix Configuration
# ============================================================================
SKIP_MATRIX_ONBOARDING=false
MATRIX_HOME_SERVER=https://mx.ixo.earth
MATRIX_BOT_URL=https://rooms.bot.mx.ixo.earth
MATRIX_STATE_BOT_URL=https://state.bot.mx.ixo.earth
MATRIX_READ_ENABLED=true

# ============================================================================
# Claims Bot Configuration
# ============================================================================
CLAIMS_BOT_URL=https://your-claims-bot-production-url.com
CLAIMS_BOT_ACCESS_TOKEN=YOUR_PRODUCTION_ACCESS_TOKEN_HERE
# Optional: Database encryption key (base64-encoded)
# CLAIMS_BOT_DB_ENCRYPTION_KEY=base64-encoded-key-here

# ============================================================================
# SMS Configuration (Africa's Talking)
# ============================================================================
SMS_ENABLED=true
AFRICASTALKING_API_KEY=YOUR_PRODUCTION_API_KEY_HERE
AFRICASTALKING_USERNAME=supamoto
AFRICASTALKING_SENDER_ID=SupaMoto

# ============================================================================
# System Security
# ============================================================================
# CRITICAL: Generate strong random values for production
# Use: openssl rand -hex 32
SYSTEM_SECRET=CHANGE_ME_GENERATE_RANDOM_64_CHAR_HEX
PIN_ENCRYPTION_KEY=CHANGE_ME_GENERATE_RANDOM_64_CHAR_HEX
ENCRYPTION_KEY=CHANGE_ME_GENERATE_RANDOM_64_CHAR_HEX

# Demo credentials (disable in production)
DEMO_PIN=
DEMO_PIN_HASH=

# ============================================================================
# USSD Configuration
# ============================================================================
USSD_MACHINE_TYPE=supamoto
ZM_SERVICE_CODES=*2233#
ZM_SUPPORT_PHONE=+260700000000
OTP_VALIDITY_MINUTES=10
MAX_PIN_ATTEMPTS=3
DELIVERY_CONFIRMATION_DAYS=7
SMS_RETRY_ATTEMPTS=3
TIMEZONE=Africa/Nairobi

# ============================================================================
# Bean Distribution Configuration
# ============================================================================
BEAN_DISTRIBUTION_COLLECTION_ID=120

# CRITICAL: Wallet mnemonics for blockchain transactions
# NEVER commit these to version control
# Store in secure secrets management system (AWS Secrets Manager, HashiCorp Vault, etc.)
LG_WALLET_MNEMONIC="word1 word2 word3 ... word24"
EVALUATOR_WALLET_MNEMONIC="word1 word2 word3 ... word24"

# ============================================================================
# Claims Retry Configuration
# ============================================================================
CLAIMS_MAX_RETRIES=3
CLAIMS_RETRY_BATCH_SIZE=10

