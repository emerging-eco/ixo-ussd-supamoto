PG_USER=postgres
PG_PASSWORD=postgres
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=ixo-ussd-dev

# IXO Platform
# Network type controls all blockchain URLs (devnet, testnet, mainnet, local)
