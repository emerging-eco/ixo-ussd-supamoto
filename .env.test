# Server Configuration
NODE_ENV=development
PORT=3005
SERVER_DISABLE_REQUEST_LOGGING=false
TRUST_PROXY_ENABLED=false
LOG_LEVEL=debug
LOG_NAME=ixo-ussd-server
# USSD_MACHINE_TYPE is useful when you have different USSD machines in the same project
USSD_MACHINE_TYPE=example

# Database Configuration
DATABASE_URL="postgres://postgres:postgres@localhost:5432/ixo-ussd-dev"
PG_USER=postgres
PG_PASSWORD=postgres
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=ixo-ussd-dev

# IXO Platform
# Network type controls all blockchain URLs (RPC, Blocksync) - URLs are auto-selected based on CHAIN_NETWORK value
CHAIN_NETWORK=devnet
# Matrix Configuration
MATRIX_HOME_SERVER="https://devmx.ixo.earth"
MATRIX_BOT_URL="https://rooms.bot.devmx.ixo.earth"
MATRIX_STATE_BOT_URL="https://state.bot.devmx.ixo.earth"
# Lead Generation (optional - for IXO claims)
LEADGEN_COLLECTION_ID=410
LEADGEN_TEMPLATE_URL=https://devmx.ixo.earth/_matrix/media/v3/download/devmx.ixo.earth/LWCamzPswXpgrfwyyJvcjzoK

# Claims Bot Configuration (for 1,000 Day Household Survey)
CLAIMS_BOT_URL=https://test-claims-bot-url.com
CLAIMS_BOT_ACCESS_TOKEN=test-access-token

# Logging
LOG_LEVEL=info
LOG_NAME=ixo-ussd

# System
SYSTEM_SECRET=your_system_secret
PIN_ENCRYPTION_KEY="ff7465fb16a9956a59816023838c4e31a7a5c690ff047eacc6c93ee61933f472"
DEMO_PIN=your_demo_pin
DEMO_PIN_HASH=your_demo_pin_hash
METRICS_ENABLED=true
OTP_VALIDITY_MINUTES=10
MAX_PIN_ATTEMPTS=3
DELIVERY_CONFIRMATION_DAYS=7
SMS_RETRY_ATTEMPTS=3
TIMEZONE=Africa/Nairobi

# Service Codes
ZM_SERVICE_CODES=*2233#
ZM_SUPPORT_PHONE=0700000000

# SMS Configuration (Africa's Talking) - Sandbox configuration below
SMS_ENABLED=true
AFRICASTALKING_API_KEY=atsk_02167bc2160760839c4bf3e9a33797e97e1851500cc6354e49e9e2170a5be3bcd8497298
AFRICASTALKING_USERNAME=sandbox
AFRICASTALKING_SENDER_ID=

# Claims Retry Configuration
CLAIMS_MAX_RETRIES=3
CLAIMS_RETRY_BATCH_SIZE=10
