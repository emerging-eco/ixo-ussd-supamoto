# Server Configuration
NODE_ENV=development
PORT=3005
HOST=0.0.0.0
SERVER_DISABLE_REQUEST_LOGGING=false
TRUST_PROXY_ENABLED=false
LOG_LEVEL=debug
LOG_NAME=ixo-ussd-server
# USSD_MACHINE_TYPE is useful when you have different USSD machines in the same project
USSD_MACHINE_TYPE=example

# Database Configuration
DATABASE_URL=postgres://user:password@localhost:5432/ixo_ussd_supamoto
PG_USER=user
PG_PASSWORD=password
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=ixo-ussd-supamoto

# IXO Platform
# Network type controls all blockchain URLs (devnet, testnet, mainnet, local)
CHAIN_NETWORK=devnet
CHAIN_RPC_URL=https://devnet.ixo.earth/rpc/
# Feegrant Configuration
FEEGRANT_AUTH_MAINNET=""
FEEGRANT_AUTH_TESTNET=""
FEEGRANT_AUTH_DEVNET=""
FEEGRANT_AUTH_LOCAL=""
FEEGRANT_URL="https://feegrant.devnet.ixo.earth"
FEEGRANT_GRANTER="your_feegranter_address"
# Matrix Configuration
SKIP_MATRIX_ONBOARDING=false
MATRIX_HOME_SERVER="https://devmx.ixo.earth"
MATRIX_BOT_URL="https://rooms.bot.devmx.ixo.earth"
MATRIX_STATE_BOT_URL="https://state.bot.devmx.ixo.earth"
MATRIX_READ_ENABLED=false
# Claims Bot Configuration
# Used for submitting claims via the @ixo/supamoto-bot-sdk
# The SDK provides three clients:
#   1. API Client (createApiClient) - Read customer data, claims, collection IDs via HTTP
#   2. Claims Bot Client (createClaimsBotClient) - Submit claims via HTTP (currently used)
#   3. Database Client (createDatabaseClient) - Direct PostgreSQL access with encryption
# Current usage:
#   - Lead creation claims (submitted during customer account creation)
#   - 1,000 Day Household survey claims
# See docs/supamoto/SUPAMOTO_BOT_SDK_GUIDE.md for comprehensive SDK usage guide
CLAIMS_BOT_URL=https://your-claims-bot-url.com
CLAIMS_BOT_ACCESS_TOKEN=your-access-token-here
# Optional: Encryption key for Database Client (base64-encoded, not currently used)
# CLAIMS_BOT_DB_ENCRYPTION_KEY=base64-encoded-encryption-key

# Logging
LOG_LEVEL=info
LOG_NAME=ixo-ussd

# System
SYSTEM_SECRET=your_system_secret
PIN_ENCRYPTION_KEY="ff7465fb16a9956a59816023838c4e31a7a5c690ff047eacc6c93ee61933f472"
DEMO_PIN=your_demo_pin
DEMO_PIN_HASH=your_demo_pin_hash
METRICS_ENABLED=true
OTP_VALIDITY_MINUTES=10
MAX_PIN_ATTEMPTS=3
DELIVERY_CONFIRMATION_DAYS=7
SMS_RETRY_ATTEMPTS=3
TIMEZONE=Africa/Nairobi

# Service Codes
ZM_SERVICE_CODES=*2233#
ZM_SUPPORT_PHONE=0700000000

# SMS Configuration (Africa's Talking) - Sandbox configuration below
SMS_ENABLED=true
AFRICASTALKING_API_KEY=your-api-key-here
AFRICASTALKING_USERNAME=supamoto
AFRICASTALKING_SENDER_ID=
