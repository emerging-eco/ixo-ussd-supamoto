{
  "name": "ixo-ussd-server",
  "version": "0.1.0",
  "description": "A USSD server implementation for ixo platform integration",
  "repository": "https://github.com/emerging-eco/ixo-ussd-supamoto",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "scripts": {
    "build": "pnpm build:clean && pnpm build:compile && pnpm build:alias && pnpm build:copy && pnpm build:verify",
    "build:clean": "rimraf dist",
    "build:compile": "tsc --project tsconfig.build.json",
    "build:alias": "tsc-alias -p tsconfig.build.json",
    "build:copy": "node scripts/build/copy-migrations.js",
    "build:verify": "node scripts/build/verify-build.js",
    "copy-sql": "node scripts/build/copy-migrations.js",
    "dev": "NODE_ENV=dev node --watch --env-file=.env.local --loader ts-node/esm src/index.ts --no-warnings",
    "start": "node scripts/build/start-production.js",
    "test": "vitest --run --reporter=verbose",
    "test:watch": "vitest",
    "test:coverage": "vitest --coverage --run",
    "test:interactive": "NODE_OPTIONS='--loader ts-node/esm' ts-node --require dotenv/config tests/scripts/test-interactive.ts",
    "test:data": "NODE_OPTIONS='--loader ts-node/esm' ts-node --require dotenv/config tests/scripts/test-data.ts",
    "generate:test": "NODE_OPTIONS='--loader ts-node/esm' ts-node --require dotenv/config tests/scripts/test-generate-tests-from-logs.ts",
    "record:flows": "NODE_OPTIONS='--loader ts-node/esm' ts-node tests/scripts/record-all-flows.ts",
    "test:integration": "NODE_OPTIONS='--loader ts-node/esm' ts-node tests/scripts/test-integration-flows.ts",
    "test:integration:record": "NODE_OPTIONS='--loader ts-node/esm' ts-node tests/scripts/test-integration-flows.ts --record",
    "test:all": "pnpm format && pnpm lint && pnpm tsc --noEmit && pnpm build && pnpm validate:machines && pnpm test",
    "test:flows": "vitest --config vitest.flows.config.ts",
    "test:flows:run": "vitest run --config vitest.flows.config.ts",
    "test:flows:knowmore": "vitest run --config vitest.flows.config.ts tests/fixtures/flows/know-more-flow.test.ts",
    "test:flows:createcustomer": "vitest run --config vitest.flows.config.ts tests/fixtures/flows/create-customer-flow.test.ts",
    "test:flows:activatecustomer": "vitest run --config vitest.flows.config.ts tests/fixtures/flows/activate-customer-flow.test.ts",
    "test:flows:1000daysurvey": "vitest run --config vitest.flows.config.ts tests/fixtures/flows/1000-day-household-survey-flow.test.ts",
    "test:database-integration": "NODE_OPTIONS='--loader ts-node/esm' ts-node --require dotenv/config scripts/test-database-integration.ts",
    "anonymise": "NODE_OPTIONS='--loader ts-node/esm' ts-node src/anonymise.ts",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,md}\" \"*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,md}\" \"*.{ts,tsx,js,jsx,json,md}\"",
    "lint": "eslint \"src/**/*.{ts,tsx,js,jsx}\" \"tests/**/*.{ts,tsx,js,jsx}\" \"scripts/**/*.{ts,tsx,js,jsx}\" --fix",
    "validate:machines": "node scripts/validate-machines.mjs",
    "validate:csv": "NODE_OPTIONS='--loader ts-node/esm' ts-node scripts/validate-csv-import.ts",
    "view:db-queries": "NODE_ENV=dev DOTENV_CONFIG_PATH=.env.local NODE_OPTIONS='--loader ts-node/esm' ts-node --require dotenv/config scripts/db-queries.ts",
    "import:customers": "NODE_ENV=dev DOTENV_CONFIG_PATH=.env.local NODE_OPTIONS='--loader ts-node/esm' ts-node --require dotenv/config scripts/import-customers-from-csv.ts",
    "export:credentials": "NODE_ENV=dev DOTENV_CONFIG_PATH=.env.local NODE_OPTIONS='--loader ts-node/esm' ts-node --require dotenv/config scripts/export-customer-credentials.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@cosmjs/amino": "0.34.0",
    "@cosmjs/crypto": "^0.34.0",
    "@cosmjs/encoding": "0.34.0",
    "@cosmjs/proto-signing": "0.34.0",
    "@cosmjs/stargate": "0.34.0",
    "@fastify/cors": "^11.1.0",
    "@fastify/formbody": "^8.0.2",
    "@fastify/helmet": "^13.0.1",
    "@fastify/postgres": "^6.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/sensible": "^6.0.3",
    "@ixo/impactxclient-sdk": "2.4.1",
    "@ixo/matrixclient-sdk": "^0.3.4",
    "@ixo/supamoto-bot-sdk": "0.1.3",
    "@types/blocked-at": "^1.0.4",
    "@types/md5": "^2.3.5",
    "@types/node": "^24.2.0",
    "@types/pg": "^8.15.5",
    "@types/react-dom": "^19.1.7",
    "africastalking": "^0.7.3",
    "axios": "1.11.0",
    "bcrypt": "^6.0.0",
    "bignumber.js": "9.3.1",
    "blocked-at": "^1.2.0",
    "bs58": "6.0.0",
    "cbor": "10.0.10",
    "copyfiles": "^2.4.1",
    "crypto-js": "4.2.0",
    "csv-parse": "^5.5.0",
    "csv-stringify": "^6.4.0",
    "eciesjs": "^0.4.15",
    "fastify": "5.4.0",
    "fastify-metrics": "^12.1.0",
    "fastify-plugin": "^5.0.1",
    "graphql-request": "^7.2.0",
    "iconv-lite": "^0.6.3",
    "kysely": "^0.28.4",
    "libphonenumber-js": "^1.12.10",
    "long": "^5.3.2",
    "matrix-js-sdk": "37.12.0",
    "md5": "^2.3.0",
    "moment-timezone": "^0.6.0",
    "nats": "^2.29.3",
    "newman": "^6.2.1",
    "pg": "^8.16.3",
    "pino": "^9.7.0",
    "protobufjs": "^7.5.3",
    "secure-web-storage": "1.0.2",
    "ts-essentials": "^10.1.1",
    "ts-node": "^10.9.2",
    "xstate": "^5.20.1",
    "zod": "^4.0.14"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.32.0",
    "@faker-js/faker": "^9.9.0",
    "@release-it/conventional-changelog": "^10.0.1",
    "@testing-library/jest-dom": "^6.6.4",
    "@types/autocannon": "^7.12.7",
    "@types/crypto-js": "4.2.2",
    "@types/node": "^18.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "auto-changelog": "^2.5.0",
    "autocannon": "^8.0.0",
    "conventional-changelog-conventionalcommits": "^7.0.2",
    "dotenv-cli": "^10.0.0",
    "globals": "^16.3.0",
    "madge": "^8.0.0",
    "release-it": "^19.0.4",
    "rimraf": "^6.0.1",
    "semantic-release": "22",
    "testcontainers": "^11.5.0",
    "ts-node-dev": "^2.0.0",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.20.3",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  },
  "optionalDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.38.0",
    "@typescript-eslint/parser": "^8.38.0",
    "@xstate/cli": "^0.5.17",
    "dotenv": "^17.2.1",
    "eslint": "^9.32.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.3",
    "pino-debug": "^3.0.0",
    "pino-pretty": "^13.1.1",
    "prettier": "^3.6.2",
    "ts-standard": "^12.0.2",
    "typesafe-i18n": "^5.26.2"
  }
}
